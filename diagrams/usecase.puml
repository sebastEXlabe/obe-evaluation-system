@startuml
' 图3-1 系统用例图
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Times New Roman
skinparam defaultFontSize 12
skinparam actorBorderColor #3C5488
skinparam usecaseBorderColor #3C5488
skinparam usecaseBackgroundColor #F5F7FA
skinparam packageBorderColor #4DBBD5
skinparam packageBackgroundColor #FFFFFF
skinparam packageFontColor #2C3E50
skinparam packageStyle rectangle

left to right direction

actor 管理员 as Admin
actor 教师 as Teacher
actor 学生 as Student

rectangle "用户与课程管理" {
  usecase "用户管理" as UC1
  usecase "课程目标设定" as UC2
  usecase "AHP权重校验" as UC3
  usecase "CO-PO映射" as UC4
}

rectangle "小组与项目管理" {
  usecase "小组创建与分配" as UC5
  usecase "岗位变更管理" as UC6
  usecase "里程碑与任务" as UC7
  usecase "Git提交同步" as UC8
}

rectangle "评价与分析" {
  usecase "小组评分" as UC9
  usecase "贡献度计算" as UC10
  usecase "岗位评价" as UC11
  usecase "达成度分析" as UC12
}

rectangle "AI辅助" {
  usecase "智能问答" as UC13
  usecase "自测练习" as UC14
  usecase "学情预警" as UC15
}

Admin --> UC1
Teacher --> UC2
Teacher --> UC3
Teacher --> UC4
Teacher --> UC5
Teacher --> UC6
Teacher --> UC7
Teacher --> UC8
Teacher --> UC9
Teacher --> UC10
Teacher --> UC11
Teacher --> UC12
Student --> UC7
Student --> UC8
Student --> UC10
Student --> UC12
Student --> UC13
Student --> UC14
@enduml
